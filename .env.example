APP_ENV=production
SITE_BASE_URL=https://vagasrj.rio.br
SITE_NAME=Vagas RJ
SITE_CONTACT_EMAIL=contato@vagasrj.rio.br

ADMIN_USERNAME=admin
ADMIN_PASSWORD=troque-esta-senha
# ADMIN_PASSWORD_HASH=$2y$10$...

# Anúncios: false desativa script e blocos (padrão desligado até aprovação AdSense)
ADS_ENABLED=false

# Publisher AdSense (ca-pub)
ADSENSE_CLIENT_ID=ca-pub-4279201625870524

# Slots de anúncio (IDs numéricos do painel AdSense — deixe vazio até configurar)
ADSENSE_SLOT_HOME=
ADSENSE_SLOT_HOME_SECOND=
ADSENSE_SLOT_LISTING=
ADSENSE_SLOT_LISTING_SIDEBAR=
ADSENSE_SLOT_JOB_DETAIL=
ADSENSE_SLOT_JOB_SIDEBAR=
ADSENSE_SLOT_JOB_DETAIL_SECOND=
ADSENSE_SLOT_BLOG=
ADSENSE_SLOT_BLOG_LISTING=
ADSENSE_SLOT_BLOG_MIDDLE=
ADSENSE_SLOT_BLOG_END=
ADSENSE_SLOT_BLOG_SIDEBAR=
ADSENSE_SLOT_ARTICLE_SIDEBAR=
ADSENSE_SLOT_CITY=
ADSENSE_SLOT_CATEGORY=
ADSENSE_SLOT_COMPANY=

# Em development, mostra blocos discretos quando slots ainda não estão configurados
SHOW_AD_PLACEHOLDERS_IN_DEV=true
