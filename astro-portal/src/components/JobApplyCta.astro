---
import type { ApplyChannel } from '../lib/apply-channel';
import { getApplyPrimaryCta } from '../lib/apply-channel';

interface Props {
  channel: ApplyChannel;
  note?: string;
}

const { channel, note } = Astro.props;
const cta = getApplyPrimaryCta(channel);
const defaultNote =
  'O Vagas RJ divulga vagas de terceiros. A candidatura é concluída no site ou contato da empresa contratante.';
---

{cta && (
  <div class="job-apply-cta-wrap">
    <div class="job-apply-cta">
      <p class="job-apply-cta-note">{note ?? defaultNote}</p>
      <a
        class="btn btn-accent btn-lg btn-full job-apply-cta-btn"
        href={cta.href}
        aria-label={cta.ariaLabel}
        {...(cta.external ? { target: '_blank', rel: 'noopener noreferrer' } : {})}
      >
        {cta.label}
      </a>
    </div>
  </div>
)}
