---
import type { ApplyChannel } from '../lib/apply-channel';
import { getApplyJobStepCta } from '../lib/apply-channel';

interface Props {
  channel: ApplyChannel;
  jobSlug: string;
  note?: string;
}

const { channel, jobSlug, note } = Astro.props;
const cta = getApplyJobStepCta(channel, jobSlug);
const defaultNote =
  'O Vagas RJ divulga vagas de terceiros. Na próxima etapa você confere os avisos e segue para o canal oficial da empresa.';
---

{cta && (
  <div class="job-apply-cta-wrap">
    <div class="job-apply-cta">
      <p class="job-apply-cta-note">{note ?? defaultNote}</p>
      <a
        class="btn btn-accent btn-lg btn-full job-apply-cta-btn"
        href={cta.href}
        aria-label={cta.ariaLabel}
      >
        {cta.label}
      </a>
    </div>
  </div>
)}
