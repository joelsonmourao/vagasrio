---
import type { ApplyChannel } from '../lib/apply-channel';
import { getApplyJobStepCta } from '../lib/apply-channel';

interface Props {
  channel: ApplyChannel;
  jobSlug: string;
}

const { channel, jobSlug } = Astro.props;
const cta = getApplyJobStepCta(channel, jobSlug);
const invalidMessage =
  'O canal de candidatura desta vaga ainda não foi informado corretamente.';
---

<section class="job-apply-box job-apply-card">
  <p class="apply-kicker">Próximo passo</p>
  <h2>Candidatura</h2>

  {cta && (
    <>
      <a class="btn btn-lg btn-full btn-accent" href={cta.href} aria-label={cta.ariaLabel}>
        {cta.label}
      </a>
      <p class="apply-note">
        Você verá um resumo da vaga e avisos de segurança antes de seguir para o canal oficial da empresa.
      </p>
    </>
  )}

  {(channel.type === 'empty' || channel.type === 'invalid') && (
    <p class="empty-state">{invalidMessage}</p>
  )}
</section>
