---
import AdminLayout from '../../../../layouts/AdminLayout.astro';
import AdminPostFields from '../../../../components/AdminPostFields.astro';
import { blogPostById, blogCategories } from '../../../../lib/portal';

const id = Number(Astro.params.id);
const post = await blogPostById(id);
if (!post) return Astro.redirect('/admin/posts');
const categories = await blogCategories(false);
const error = Astro.url.searchParams.get('error');
---
<AdminLayout title="Editar post">
  <header class="admin-page-head">
    <div>
      <p class="admin-kicker">Blog</p>
      <h1>Editar post</h1>
      <p class="admin-lead"><a href={`/blog/${post.slug}`} target="_blank" rel="noopener">Ver no site →</a></p>
    </div>
  </header>
  {error && <p class="flash-error">{decodeURIComponent(error)}</p>}
  <form method="post" action="/api/admin/posts" class="admin-form admin-form-stacked">
    <input type="hidden" name="id" value={post.id} />
    <AdminPostFields post={post} categories={categories} isEdit />
    <div class="admin-form-actions">
      <button class="btn" type="submit">Salvar</button>
      <a class="btn btn-outline" href="/admin/posts">Voltar</a>
    </div>
  </form>
  <form method="post" action="/api/admin/posts" class="admin-form-danger" onsubmit="return confirm('Excluir este post?')">
    <input type="hidden" name="_action" value="delete" />
    <input type="hidden" name="id" value={post.id} />
    <button class="btn btn-outline admin-btn-danger" type="submit">Excluir post</button>
  </form>
</AdminLayout>
