---
import AdminLayout from '../../layouts/AdminLayout.astro';
import { getSiteSettings, SETTING_KEYS } from '../../lib/site-settings';
import { resolvePublicBaseUrl } from '../../lib/config';

const s = await getSiteSettings();
const ok = Astro.url.searchParams.get('ok');
const error = Astro.url.searchParams.get('error');
const uploaded = Astro.url.searchParams.get('uploaded');
const K = SETTING_KEYS;
---
<AdminLayout title="Configurações">
  <header class="admin-page-head">
    <div>
      <p class="admin-kicker">Sistema</p>
      <h1>Configurações</h1>
      <p class="admin-lead">Identidade do site, SEO, rastreamento e arquivos públicos.</p>
    </div>
  </header>

  {ok && <p class="flash-ok">Configurações salvas com sucesso.</p>}
  {error && <p class="flash-error">{decodeURIComponent(error)}</p>}

  <form method="post" action="/api/admin/settings" class="admin-form admin-form-settings">
    <section class="admin-card">
      <h2>Identidade do site</h2>
      <div class="admin-form-grid">
        <label>Nome do site <input name={K.siteName} value={s[K.siteName]} required /></label>
        <label>Slogan do site <input name={K.siteSubtitle} value={s[K.siteSubtitle]} /></label>
        <label class="admin-field-span-2">URL base do site <input name={K.siteBaseUrl} value={s[K.siteBaseUrl]} placeholder="https://vagasrj.com.br" /></label>
        <label>E-mail de contato <input name={K.contactEmail} type="email" value={s[K.contactEmail]} /></label>
        <label>Caminho do logo <input name={K.logoPath} value={s[K.logoPath]} placeholder="/assets/img/logo-vagas-rj.svg" /></label>
        <label>Caminho do favicon <input name={K.faviconPath} value={s[K.faviconPath]} placeholder="/favicon.svg" /></label>
        <label class="admin-field-span-2">Imagem padrão (Open Graph) <input name={K.ogImage} value={s[K.ogImage]} placeholder="/uploads/og.jpg" /></label>
      </div>
    </section>

    <section class="admin-card">
      <h2>SEO do site</h2>
      <div class="admin-form-grid">
        <label class="admin-field-span-2">Título SEO da página inicial <input name={K.homeSeoTitle} value={s[K.homeSeoTitle]} /></label>
        <label class="admin-field-span-2">Meta description da home <textarea name={K.homeSeoDescription} rows="3">{s[K.homeSeoDescription]}</textarea></label>
        <label class="admin-field-span-2">Sufixo padrão em títulos de vagas <input name={K.jobMetaSuffix} value={s[K.jobMetaSuffix]} placeholder="Vagas RJ" /></label>
        <label class="admin-field-span-2">Modelo de título — páginas de empresa <input name={K.companyMetaTemplate} value={s[K.companyMetaTemplate]} placeholder="Vagas na {empresa} - Rio de Janeiro | Vagas RJ" /></label>
        <label class="admin-field-span-2">Modelo de título — páginas de cidade <input name={K.cityMetaTemplate} value={s[K.cityMetaTemplate]} placeholder="Vagas em {cidade} RJ - Vagas RJ" /></label>
        <label class="admin-field-check admin-field-span-2">
          <input type="hidden" name={K.indexingEnabled} value="0" />
          <input type="checkbox" name={K.indexingEnabled} value="1" checked={s[K.indexingEnabled] !== '0'} />
          Permitir indexação do site nos buscadores
        </label>
        <label class="admin-field-check admin-field-span-2">
          <input type="hidden" name={K.sitemapNote} value="0" />
          <input type="checkbox" name={K.sitemapNote} value="1" checked={s[K.sitemapNote] !== '0'} />
          Incluir URLs no sitemap.xml
        </label>
        <label class="admin-field-span-2">Linhas extras do robots.txt <textarea name={K.robotsExtra} rows="4" placeholder="Uma regra por linha (opcional)">{s[K.robotsExtra]}</textarea></label>
      </div>
      <p class="admin-hint">
        <a href="/sitemap.xml" target="_blank" rel="noopener">Ver sitemap.xml</a>
        {' · '}
        <a href="/robots.txt" target="_blank" rel="noopener">Ver robots.txt</a>
        {' · '}
        URL pública resolvida: {resolvePublicBaseUrl(s)}
      </p>
    </section>

    <section class="admin-card">
      <h2>Google e anúncios</h2>
      <div class="admin-form-grid">
        <label class="admin-field-span-2">Código de verificação (Search Console) <input name={K.gscVerification} value={s[K.gscVerification]} placeholder="Cole só o valor do content=..." /></label>
        <p class="admin-hint admin-field-span-2">Alternativa: arquivo em <code>/public/google561190fa7bebb1e0.html</code> (já suportado pelo Astro).</p>
        <label class="admin-field-span-2">Google Analytics (ID G-... ou script completo) <textarea name={K.gaCode} rows="3" placeholder="G-XXXXXXXX ou &lt;script&gt;...">{s[K.gaCode]}</textarea></label>
        <label class="admin-field-check admin-field-span-2">
          <input type="hidden" name={K.adsenseEnabled} value="0" />
          <input type="checkbox" name={K.adsenseEnabled} value="1" checked={s[K.adsenseEnabled] === '1'} />
          Ativar script do Google AdSense no site (use só após revisão/aprovação)
        </label>
        <label class="admin-field-span-2">AdSense — Publisher ID (ca-pub-...) <input name={K.adsenseClient} value={s[K.adsenseClient]} placeholder="ca-pub-XXXXXXXXXXXXXXXX" /></label>
        <label class="admin-field-span-2">AdSense — Script completo no &lt;head&gt; (opcional, para verificação) <textarea name={K.adsenseScript} rows="4" placeholder="Cole o script fornecido pelo Google, se houver">{s[K.adsenseScript]}</textarea></label>
        <label class="admin-field-span-2">Conteúdo do ads.txt <textarea name={K.adsTxt} rows="3" placeholder="google.com, pub-XXXXXXXXXXXXXXXX, DIRECT, f08c47fec0942fa0">{s[K.adsTxt]}</textarea></label>
        <p class="admin-hint admin-field-span-2">
          <a href="/ads.txt" target="_blank" rel="noopener">Ver ads.txt</a> — obrigatório em produção para AdSense.
        </p>
      </div>
    </section>

    <div class="admin-form-actions">
      <button class="btn" type="submit">Salvar configurações</button>
    </div>
  </form>

  <section class="admin-card">
    <h2>Enviar imagens</h2>
    {uploaded && <p class="flash-ok">Arquivo enviado: <a href={uploaded} target="_blank" rel="noopener">{uploaded}</a></p>}
    <form method="post" action="/api/admin/upload" enctype="multipart/form-data" class="admin-form">
      <label>Imagem (png, jpg, webp, svg) <input type="file" name="file" accept="image/*" required /></label>
      <button class="btn btn-outline" type="submit">Enviar para /public/uploads</button>
    </form>
    <p class="admin-hint">Use o caminho retornado nos campos de logo, favicon ou Open Graph acima.</p>
  </section>

  <section class="admin-card">
    <h2>Variáveis de ambiente (.env)</h2>
    <p class="admin-hint">Para produção, configure também: ADMIN_USERNAME, ADMIN_PASSWORD_HASH, SESSION_SECRET, DATABASE_URL. Não use a senha padrão admin/admin123 em produção.</p>
  </section>
</AdminLayout>
