---
import BaseLayout from '../layouts/BaseLayout.astro';
import { institutionalPages } from '../lib/institutional';
import { baseUrl, siteConfig } from '../lib/config';
import { getSiteSettingsSafe } from '../lib/site-settings';
const cfg = siteConfig;
const page = institutionalPages.contato;
const settings = await getSiteSettingsSafe();
---
<BaseLayout title={`${page.title} - ${siteConfig.name}`} description={page.description} canonical={baseUrl('/contato', settings)}>
  <h1>{page.title}</h1>
  <div class="prose" set:html={page.html.replace('contato@vagasrj.rio.br', cfg.contactEmail)} />
</BaseLayout>
