---
import BaseLayout from '../../layouts/BaseLayout.astro';
import JobCard from '../../components/JobCard.astro';
import JobApplyBox from '../../components/JobApplyBox.astro';
import JobApplyCta from '../../components/JobApplyCta.astro';
import JobMobileApplyBar from '../../components/JobMobileApplyBar.astro';
import { jobBySlug, jobList, articleList } from '../../lib/portal';
import { buildJobPostingSchema, formatJobStreetAddressDisplay, resolveJobStreetAddress } from '../../lib/job-posting';
import {
  buildJobPageTitle,
  buildJobPageDescription,
  buildBreadcrumbSchema,
  jobCanonical,
  jobRobotsMeta,
  mergeJsonLd,
} from '../../lib/seo';
import { getSiteSettingsSafe, isIndexingEnabled } from '../../lib/site-settings';
import {
  employmentTypeLabel,
  formatJobPublishedBr,
  formatSalaryDisplay,
  formatJobValidThroughBr,
} from '../../lib/format';
import { parseApplyChannel } from '../../lib/apply-channel';
import { jobIsPubliclyVisible } from '../../lib/public-content';

const { slug } = Astro.params;
const job = slug ? await jobBySlug(slug) : null;
if (!job) return Astro.redirect('/404');

const settings = await getSiteSettingsSafe();
const indexingOn = isIndexingEnabled(settings);
const title = buildJobPageTitle(job, settings);
const description = buildJobPageDescription(job, settings);
const canonical = jobCanonical(job, settings);
const publiclyVisible = jobIsPubliclyVisible(job);
const robots = jobRobotsMeta(job, indexingOn, publiclyVisible);
const jsonLd = mergeJsonLd(
  buildJobPostingSchema(job, settings),
  buildBreadcrumbSchema(
    [
      { name: 'Início', path: '/' },
      { name: 'Vagas', path: '/vagas' },
      { name: job.title, path: `/vagas/${job.slug}` },
    ],
    settings,
  ),
);
const typeLabel = employmentTypeLabel(job.employmentType);
const applyChannel = parseApplyChannel(job.applyUrl);
const jobStreetAddress = resolveJobStreetAddress(job);
const jobAddressDisplay = formatJobStreetAddressDisplay(job);
const jobSalaryDisplay = formatSalaryDisplay(job.salary);

function filterRelated<T extends { slug: string }>(items: T[], currentSlug: string): T[] {
  return items.filter((j) => j.slug !== currentSlug && j.slug.trim());
}

const [relatedCity, relatedCategory, blogSafety, blogTips] = await Promise.all([
  jobList({ city: job.city.slug, perPage: 4, page: 1 }),
  job.category ? jobList({ category: job.category.slug, perPage: 4, page: 1 }) : Promise.resolve({ jobs: [] }),
  articleList({ category: 'seguranca-para-candidatos', perPage: 4, activeOnly: true }),
  articleList({ category: 'dicas-para-candidatura', perPage: 4, activeOnly: true }),
]);

const relatedCityJobs = filterRelated(relatedCity.jobs, job.slug)
  .filter((j) => jobIsPubliclyVisible(j))
  .slice(0, 3);
const relatedCategoryJobs = filterRelated(relatedCategory.jobs, job.slug)
  .filter((j) => jobIsPubliclyVisible(j))
  .slice(0, 3);

const blogRelatedMap = new Map<string, (typeof blogSafety.articles)[number]>();
for (const post of [...blogSafety.articles, ...blogTips.articles]) {
  if (!blogRelatedMap.has(post.slug)) blogRelatedMap.set(post.slug, post);
}
const blogRelated = [...blogRelatedMap.values()].slice(0, 4);
---

<BaseLayout title={title} description={description} canonical={canonical} robots={robots} jsonLd={jsonLd}>
  <nav class="breadcrumb" aria-label="Navegação">
    <a href="/">Início</a><span>/</span>
    <a href="/vagas">Vagas</a><span>/</span>
    <span>{job.title}</span>
  </nav>

  <article class="job-detail" data-job-detail-page>
    <header class="job-detail-hero">
      <div class="job-detail-hero-inner">
        <div class="job-detail-title-wrap">
          {job.category && <span class="tag tag-lg tag-category">{job.category.name}</span>}
          <h1>{job.title}</h1>
          <p class="job-detail-lead">
            <span class="job-detail-company">{job.company.name}</span>
            <span class="job-detail-sep" aria-hidden="true">·</span>
            <span class="job-detail-city">{job.city.name}/RJ</span>
          </p>
        </div>
        <div class="job-detail-hero-meta">
          <span>Publicada em {formatJobPublishedBr(job.publishedAt)}</span>
          {typeLabel && <span>{typeLabel}</span>}
          <span>{jobSalaryDisplay}</span>
        </div>
      </div>
    </header>

    <div class="job-detail-layout">
      <div class="job-detail-main">
        <section class="panel panel-compact job-detail-intro">
          <h2 class="visually-hidden">Resumo da vaga</h2>
          <ul class="summary-list summary-list--inline">
            <li><span>Empresa</span><strong>{job.company.name}</strong></li>
            <li><span>Cidade</span><strong>{job.city.name}/RJ</strong></li>
            <li><span>Salário</span><strong>{jobSalaryDisplay}</strong></li>
            {!jobStreetAddress && (
              <li><span>Endereço</span><strong>{jobAddressDisplay}</strong></li>
            )}
          </ul>
        </section>

        <div class="job-apply-flow">
          <JobApplyCta channel={applyChannel} />
        </div>

        <section class="panel panel-description">
          <h2>Descrição da vaga</h2>
          <div class="prose job-description" set:html={job.description} />
        </section>

        <div class="job-apply-flow">
          <JobApplyCta channel={applyChannel} note="Leu a descrição? Continue a candidatura no canal oficial da empresa." />
        </div>

        <section class="panel panel-warning panel-security panel-security-inline">
          <div class="panel-security-icon" aria-hidden="true">!</div>
          <div>
            <h2>Aviso de segurança</h2>
            <p>O Vagas RJ apenas divulga oportunidades. Desconfie de cobranças para candidatura.</p>
          </div>
        </section>
      </div>

      <aside class="job-aside">
        <div class="job-apply-card job-apply-card--desktop">
          <JobApplyBox channel={applyChannel} />
        </div>
        <section class="panel panel-compact panel-summary">
          <h3>Resumo</h3>
          <ul class="summary-list">
            <li><span>Empresa</span><strong>{job.company.name}</strong></li>
            <li><span>Cidade</span><strong>{job.city.name}/RJ</strong></li>
            {!jobStreetAddress && (
              <li><span>Endereço</span><strong>{jobAddressDisplay}</strong></li>
            )}
            <li><span>Salário</span><strong>{jobSalaryDisplay}</strong></li>
            {job.category && <li><span>Categoria</span><strong>{job.category.name}</strong></li>}
            <li><span>Publicação</span><strong>{formatJobPublishedBr(job.publishedAt)}</strong></li>
            <li><span>Validade</span><strong>{formatJobValidThroughBr(job.validThrough, job.publishedAt)}</strong></li>
          </ul>
        </section>
        <a class="btn btn-outline btn-full" href="/vagas">← Ver mais vagas</a>
      </aside>
    </div>
  </article>

  <JobMobileApplyBar channel={applyChannel} />

  <section class="job-retention" aria-label="Explore mais no Vagas RJ">
    <nav class="job-explore-links panel panel-compact">
      <h2>Explorar no portal</h2>
      <ul class="job-explore-list">
        <li>
          <a href={`/vagas/cidade/${job.city.slug}`}>Vagas em {job.city.name}/RJ</a>
        </li>
        {job.category && (
          <li>
            <a href={`/vagas?category=${job.category.slug}`}>Vagas em {job.category.name}</a>
          </li>
        )}
        <li><a href="/vagas">Todas as vagas</a></li>
        <li><a href="/blog">Artigos e dicas</a></li>
      </ul>
    </nav>

    {relatedCityJobs.length > 0 && (
      <section class="related-section">
        <div class="section-head">
          <h2>Outras vagas em {job.city.name}</h2>
          <a class="section-link" href={`/vagas/cidade/${job.city.slug}`}>Ver todas →</a>
        </div>
        <div class="job-grid job-grid-listing">
          {relatedCityJobs.map((j) => <JobCard job={j} />)}
        </div>
      </section>
    )}

    {job.category && relatedCategoryJobs.length > 0 && (
      <section class="related-section">
        <div class="section-head">
          <h2>Mais vagas em {job.category.name}</h2>
          <a class="section-link" href={`/vagas?category=${job.category.slug}`}>Ver todas →</a>
        </div>
        <div class="job-grid job-grid-listing">
          {relatedCategoryJobs.map((j) => <JobCard job={j} />)}
        </div>
      </section>
    )}

    {blogRelated.length > 0 && (
      <section class="related-section related-articles">
        <div class="section-head">
          <h2>Dicas sobre candidatura segura</h2>
          <a class="section-link" href="/blog">Ver blog →</a>
        </div>
        <ul class="job-blog-related-list">
          {blogRelated.map((post) => (
            <li>
              <a href={`/blog/${post.slug}`}>{post.title}</a>
            </li>
          ))}
        </ul>
      </section>
    )}
  </section>
</BaseLayout>
