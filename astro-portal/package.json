{
  "name": "astro-portal",
  "type": "module",
  "version": "0.0.1",
  "engines": {
    "node": ">=22.12.0"
  },
  "scripts": {
    "dev": "npm run dev:sqlite",
    "dev:sqlite": "node scripts/dev-sqlite.mjs",
    "dev:postgres": "node scripts/dev-postgres.mjs",
    "build": "npm run build:sqlite",
    "build:sqlite": "node scripts/prisma-cli.mjs sqlite generate && astro build",
    "build:postgres": "node scripts/prisma-cli.mjs postgres generate && astro build",
    "preview": "astro preview",
    "preview:sqlite": "node scripts/preview-sqlite.mjs",
    "astro": "astro",
    "db:generate": "node scripts/prisma-cli.mjs sqlite generate",
    "db:migrate:sqlite": "node scripts/prisma-cli.mjs sqlite push",
    "db:seed:sqlite": "node scripts/prisma-cli.mjs sqlite seed",
    "db:migrate:postgres": "node scripts/prisma-cli.mjs postgres migrate",
    "db:seed:postgres": "node scripts/prisma-cli.mjs postgres seed",
    "db:deploy:postgres": "node scripts/prisma-cli.mjs postgres deploy",
    "export:legacy": "python ../scripts/export-sqlite-for-astro.py",
    "setup:local": "npm run export:legacy && npm run db:migrate:sqlite && npm run db:seed:sqlite",
    "slug:redirects": "node scripts/generate-legacy-slug-redirects.mjs",
    "slug:fix-seed": "node scripts/fix-local-slugs.mjs && npm run slug:redirects",
    "audit:links": "node scripts/audit-links.mjs",
    "postinstall": "node scripts/prisma-cli.mjs sqlite generate"
  },
  "prisma": {
    "seed": "npx tsx prisma/seed.ts"
  },
  "dependencies": {
    "@astrojs/node": "^10.1.3",
    "@prisma/client": "^5.22.0",
    "astro": "^6.4.3",
    "bcryptjs": "^3.0.3",
    "prisma": "^5.22.0",
    "xlsx": "^0.18.5",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@types/bcryptjs": "^2.4.6",
    "tsx": "^4.22.4"
  }
}
